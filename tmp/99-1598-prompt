	cmd := &cobra.Command{
		Use:     "cluster",
		Aliases: []string{"clusters"},
		Short:   "Manage local clusters",
		Long: `Manage local development clusters with Knative, Tekton, and
other components pre-installed. For more documentation, see
cluster create --help.

Create a minimal cluster:
  func cluster create --serving=false --eventing=false --tekton=false

Remove the cluster and associated resources:
  func cluster delete`,
	}
	cmd.AddCommand(NewClusterCreateCmd())
	cmd.AddCommand(NewClusterDeleteCmd())
	cmd.AddCommand(NewClusterListCmd())
	return cmd
}

