// newClusterConfig reads all cluster configuration from viper,
// which merges flag values, environment variables, and defaults.
func newClusterConfig() cluster.ClusterConfig {
	name := viper.GetString("name")
	if name == "" {
		name = "func"
	}

	configDir := config.Dir()

	cfg := cluster.ClusterConfig{
		Name:               name,
		Domain:             viper.GetString("domain"),
		Serving:            viper.GetBool("serving"),
		Eventing:           viper.GetBool("eventing"),
		Tekton:             viper.GetBool("tekton"),
		Keda:               viper.GetBool("keda"),
		Dapr:               viper.GetBool("dapr"),
		Retries:            viper.GetInt("retries"),
		ContainerEngine:    viper.GetString("container-engine"),
		Namespace:          viper.GetString("namespace"),
		NeedSudo:           viper.GetBool("need-sudo"),
		Verbose:            viper.GetBool("verbose"),
		RegistryPort:       viper.GetInt("registry-port"),
		PacHost:            viper.GetString("pac-host"),
		SkipBinaries:       viper.GetBool("skip-binaries"),
		SkipRegistryConfig: viper.GetBool("skip-registry-config"),
		NoCleanup:          viper.GetBool("no-cleanup"),
		GitHubActions:      os.Getenv("GITHUB_ACTIONS") == "true",
		ConfigDir:          configDir,
		BinDir:             filepath.Join(configDir, "bin"),
		Kubeconfig:         filepath.Join(configDir, "clusters", name+".local", "kubeconfig.yaml"),
	}

	// Apply defaults for empty strings (viper returns "" for unset strings)
	if cfg.Domain == "" {
		cfg.Domain = "localtest.me"
	}
	if cfg.ContainerEngine == "" {
		cfg.ContainerEngine = "docker"
	}
	if cfg.Namespace == "" {
		cfg.Namespace = "default"
	}
	if cfg.PacHost == "" {
		cfg.PacHost = fmt.Sprintf("pac-ctr.%s", cfg.Domain)
	}
	if cfg.RegistryPort == 0 {
		cfg.RegistryPort = 50000
	}
	if cfg.Retries == 0 {
		cfg.Retries = 1
	}

	return cfg
}
