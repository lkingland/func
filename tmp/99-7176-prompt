package cluster

import (
	"encoding/json"
	"errors"
	"fmt"
	"io"
	"io/fs"
	"os"
	"os/exec"
	"path/filepath"
	"runtime"
	"strings"
	"time"
)

// configureHostRegistry configures the host's container engine(s) to trust
// the local insecure registry. This is the Go equivalent of hack/registry.sh.
func configureHostRegistry(cfg ClusterConfig, out io.Writer) error {
	start := time.Now()
	fmt.Fprintln(out, blue("Enabling Insecure Local Registry"))

	warnNix(out)

	fmt.Fprintln(out, "Setting registry as trusted local-only")
	registryAddr := fmt.Sprintf("localhost:%d", cfg.RegistryPort)

	// Try Docker
	if hasCommand("docker") {
		fmt.Fprintln(out, "Configuring Docker for insecure registry...")
		if err := configureDockerInsecure(registryAddr, cfg.NeedSudo, out); err != nil {
			fmt.Fprintf(out, "%s\n", yellow(fmt.Sprintf("Warning: Failed to configure Docker: %v", err)))
		}
	}

	// Try Podman
	if hasCommand("podman") {
		fmt.Fprintln(out, "Configuring Podman for insecure registry...")
		if err := configurePodmanInsecure(registryAddr, cfg.NeedSudo, out); err != nil {
			fmt.Fprintf(out, "%s\n", yellow(fmt.Sprintf("Warning: Failed to configure Podman: %v", err)))
		}
	}

	fmt.Fprintln(out, yellow(fmt.Sprintf(
		"Note: %s is now a trusted insecure registry for this machine's container engine.\n"+
			"      Any process with local access can push, pull, or delete images there,\n"+
			"      and the setting is not reverted by 'func cluster delete'.",
		registryAddr)))

	success(out, "Registry", time.Since(start))
	return nil
}

// configureDockerInsecure adds the registry to Docker's insecure-registries
// list, preserving any other daemon.json settings the user has configured.
func configureDockerInsecure(registryAddr string, needSudo bool, out io.Writer) error {
	path, useSudo := dockerDaemonPath(needSudo)

	config, err := readDockerDaemon(path, useSudo)
	if err != nil {
		return err
	}
	addInsecureRegistry(config, registryAddr)

	data, err := json.MarshalIndent(config, "", "  ")
	if err != nil {
		return fmt.Errorf("marshaling daemon.json: %w", err)
	}
	if err := writeFileWithSudo(path, data, useSudo); err != nil {
		return fmt.Errorf("writing daemon.json: %w", err)
	}

	fmt.Fprintf(out, "OK %s\n", path)
	if runtime.GOOS == "darwin" {
		fmt.Fprintln(out, yellow("*** If Docker Desktop is running, please restart it via the menu bar icon ***"))
	} else {
		fmt.Fprintln(out, "daemon.json updated; not restarting dockerd mid-setup (would tear down the in-progress cluster)")
	}
	return nil
}

// dockerDaemonPath returns the daemon.json path for the current OS and
// whether writing requires sudo. Darwin uses the per-user path and never
// needs sudo. Linux always writes to /etc/docker/daemon.json, which
// requires root — so sudo is forced regardless of needSudo.
func dockerDaemonPath(needSudo bool) (string, bool) {
	if runtime.GOOS == "darwin" {
		home, _ := os.UserHomeDir()
		return filepath.Join(home, ".docker", "daemon.json"), false
	}
	return "/etc/docker/daemon.json", needSudo || runtime.GOOS == "linux"
}

// readDockerDaemon loads daemon.json. A missing file returns an empty
// config (first-time setup); read/parse failures return an error so we
// don't silently overwrite a daemon.json the user has customized.
func readDockerDaemon(path string, useSudo bool) (map[string]any, error) {
	data, err := readFileWithSudo(path, useSudo)
	if errors.Is(err, fs.ErrNotExist) || (err != nil && !fileExists(path)) {
		return map[string]any{}, nil
	}
	if err != nil {
		return nil, fmt.Errorf("reading %s: %w", path, err)
	}
	if len(data) == 0 {
		return map[string]any{}, nil
	}
	var config map[string]any
	if err := json.Unmarshal(data, &config); err != nil {
		return nil, fmt.Errorf("parsing %s: %w", path, err)
	}
	if config == nil {
		config = map[string]any{}
	}
	return config, nil
}

// addInsecureRegistry appends registry to config["insecure-registries"] if
// not already present, preserving any existing entries.
func addInsecureRegistry(config map[string]any, registry string) {
	existing, _ := config["insecure-registries"].([]any)
	for _, r := range existing {
		if s, ok := r.(string); ok && s == registry {
			return
		}
	}
	config["insecure-registries"] = append(existing, registry)
}

// configurePodmanInsecure adds the registry to Podman's registries.conf.
func configurePodmanInsecure(registryAddr string, needSudo bool, out io.Writer) error {
	xdgConfig := os.Getenv("XDG_CONFIG_HOME")
	if xdgConfig == "" {
		home, _ := os.UserHomeDir()
		xdgConfig = filepath.Join(home, ".config")
	}

	userConfigDir := filepath.Join(xdgConfig, "containers")
	userConfigFile := filepath.Join(userConfigDir, "registries.conf")
	systemConfigFile := "/etc/containers/registries.conf"

	var configFile string
	var useSudo bool

	if fileExists(userConfigFile) {
		configFile = userConfigFile
		useSudo = false
		fmt.Fprintf(out, "Using existing user Podman registry config at %s\n", configFile)
	} else if fileExists(systemConfigFile) {
		configFile = systemConfigFile
		useSudo = needSudo
		fmt.Fprintf(out, "Using existing system Podman registry config at %s\n", configFile)
	} else {
		// Create user-level config
		fmt.Fprintln(out, "No existing Podman registries.conf found.")
		if err := os.MkdirAll(userConfigDir, 0o755); err != nil {
			fmt.Fprintln(out, "Could not create user config directory. Skipping Podman registry configuration.")
			return nil
		}
		configFile = userConfigFile
		fmt.Fprintf(out, "Creating new user-level Podman registry config at %s\n", configFile)
		content := fmt.Sprintf("# Podman registries configuration\n# Generated by func cluster create\n\n[[registry]]\nlocation = %q\ninsecure = true\n", registryAddr)
		if err := os.WriteFile(configFile, []byte(content), 0o644); err != nil {
			return fmt.Errorf("writing config: %w", err)
		}
		fmt.Fprintf(out, "Successfully created Podman registry configuration for %s\n", registryAddr)
		setupPodmanMacOSForwarding(registryAddr, out)
		return nil
	}

	// Read existing config
	data, err := readFileWithSudo(configFile, useSudo)
	if err != nil {
		return fmt.Errorf("reading %s: %w", configFile, err)
	}
	content := string(data)

	// Check if already configured
	if strings.Contains(content, registryAddr) {
		fmt.Fprintf(out, "%s is already configured in %s\n", registryAddr, configFile)
		return nil
	}

	// Detect v1 vs v2 format
	isV2 := strings.Contains(content, "[[registry]]")

	if isV2 {
		fmt.Fprintln(out, "Adding insecure registry (v2 format)")
		appendContent := fmt.Sprintf("\n[[registry]]\nlocation = %q\ninsecure = true\n", registryAddr)
		if err := appendFileWithSudo(configFile, []byte(appendContent), useSudo); err != nil {
			return err
		}
	} else {
		fmt.Fprintln(out, "Adding insecure registry (v1 format)")
		if strings.Contains(content, "[registries.insecure]") {
			// Section exists — insert after it
			content = strings.Replace(content, "[registries.insecure]",
				fmt.Sprintf("[registries.insecure]\nregistries = [%q]", registryAddr), 1)
			if err := writeFileWithSudo(configFile, []byte(content), useSudo); err != nil {
				return err
			}
		} else {
			appendContent := fmt.Sprintf("\n[registries.insecure]\nregistries = [%q]\n", registryAddr)
			if err := appendFileWithSudo(configFile, []byte(appendContent), useSudo); err != nil {
				return err
			}
		}
	}

	setupPodmanMacOSForwarding(registryAddr, out)
	return nil
}

// setupPodmanMacOSForwarding sets up SSH port forwarding on macOS so the
// Podman VM can access the host's local registry.
func setupPodmanMacOSForwarding(registryAddr string, out io.Writer) {
	if runtime.GOOS != "darwin" {
		return
	}
	parts := strings.SplitN(registryAddr, ":", 2)
	if len(parts) != 2 {
		return
	}
	port := parts[1]
	fmt.Fprintln(out, "Setting up port forwarding for Podman VM to access registry...")
	cmd := exec.Command("podman", "machine", "ssh", "--",
		"-L", port+":localhost:"+port, "-N", "-f")
	cmd.Stdout = out
	cmd.Stderr = out
	if err := cmd.Run(); err != nil {
		fmt.Fprintf(out, "Warning: port forwarding setup failed: %v\n", err)
	}
}

// warnNix detects Nix and emits configuration guidance.
func warnNix(out io.Writer) {
	if !hasCommand("nix") && !hasCommand("nixos-rebuild") {
		return
	}

	fmt.Fprintln(out, yellow("Warning: Nix detected"))

	if hasCommand("docker") {
		if runtime.GOOS == "darwin" {
			fmt.Fprintln(out, "If Docker Desktop was installed via Nix on macOS, you may need to manually configure the insecure registry.")
			fmt.Fprintln(out, `Please confirm "localhost:50000" is specified as an insecure registry in the docker config file.`)
		} else {
			fmt.Fprintln(out, "If Docker was configured using nix, this command will fail to find daemon.json.")
			fmt.Fprintln(out, "Please configure the insecure registry by modifying your nix config:")
			fmt.Fprintln(out, "  virtualisation.docker = {")
			fmt.Fprintln(out, "    enable = true;")
			fmt.Fprintln(out, `    daemon.settings.insecure-registries = [ "localhost:50000" ];`)
			fmt.Fprintln(out, "  };")
		}
	}

	if hasCommand("podman") {
		fmt.Fprintln(out, "If podman was configured via Nix, this command will likely fail.")
		fmt.Fprintln(out, "The configuration required is adding the following to registries.conf:")
		fmt.Fprintln(out, `  [[registry]]`)
		fmt.Fprintln(out, `  location = "localhost:50000"`)
		fmt.Fprintln(out, `  insecure = true`)
	}
}

// Helper functions

func hasCommand(name string) bool {
	_, err := exec.LookPath(name)
	return err == nil
}

func fileExists(path string) bool {
	_, err := os.Stat(path)
	return err == nil
}

func readFileWithSudo(path string, sudo bool) ([]byte, error) {
	if !sudo {
		return os.ReadFile(path)
	}
	out, err := exec.Command("sudo", "cat", path).Output()
	if err != nil {
		return nil, err
	}
	return out, nil
}

func writeFileWithSudo(path string, data []byte, sudo bool) error {
	if !sudo {
		return os.WriteFile(path, data, 0o644)
	}
	cmd := exec.Command("sudo", "tee", path)
	cmd.Stdin = strings.NewReader(string(data))
	cmd.Stdout = io.Discard
	return cmd.Run()
}

func appendFileWithSudo(path string, data []byte, sudo bool) error {
	if !sudo {
		f, err := os.OpenFile(path, os.O_APPEND|os.O_WRONLY, 0o644)
		if err != nil {
			return err
		}
		defer f.Close()
		_, err = f.Write(data)
		return err
	}
	cmd := exec.Command("sudo", "tee", "-a", path)
	cmd.Stdin = strings.NewReader(string(data))
	cmd.Stdout = io.Discard
	return cmd.Run()
}
